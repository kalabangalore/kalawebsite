# Copy to server/.env for local development.
# On Vercel, set these as Project → Settings → Environment Variables instead.

# Neon Postgres connection string (use the pooled "-pooler" host on Vercel)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Local API port (ignored on Vercel)
PORT=4000

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_SECRET=use-a-long-random-string

# Gmail SMTP, used to email payment receipt uploads as attachments instead
# of storing them anywhere. GMAIL_APP_PASSWORD is a 16-character App
# Password (Google Account -> Security -> 2-Step Verification -> App
# Passwords) — NOT the account's normal login password.
# Receipt emailing is skipped (logged, not fatal) if these aren't set.
GMAIL_USER=karnatakalibraryassociation@gmail.com
GMAIL_APP_PASSWORD=
# Optional — defaults to GMAIL_USER if unset.
RECEIPT_EMAIL_TO=
