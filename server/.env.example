# Copy to server/.env for local development.
# On Vercel, set these as Project → Settings → Environment Variables instead.

# Neon Postgres connection string (use the pooled "-pooler" host on Vercel)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Local API port (ignored on Vercel)
PORT=4000

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_SECRET=use-a-long-random-string
